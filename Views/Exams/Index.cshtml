@model IEnumerable<SmartStudyPlannerAI.Models.Entities.Exam>
@{
    ViewData["Title"] = "Examens";
    var subjects = ViewBag.Subjects as List<SmartStudyPlannerAI.Models.Entities.Subject> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-calendar-alt me-2"></i>Mes examens</h2>
    <a href="/Exams/Create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Nouvel examen
    </a>
</div>

<div class="row">
    @foreach (var exam in Model)
    {
        var subject = subjects.FirstOrDefault(s => s.Id == exam.SubjectId);
        var daysLeft = (exam.ExamDate - DateTime.Now).Days;
        <div class="col-md-4 mb-4">
            <div class="card exam-card">
                <div class="card-header d-flex justify-content-between align-items-center" style="background: linear-gradient(135deg, @(subject?.Color ?? "#667eea") 0%, #764ba2 100%);">
                    <h5 class="mb-0 text-white">@exam.Title</h5>
                    <span class="badge bg-white text-dark">@(daysLeft >= 0 ? daysLeft + " jours" : "Passe")</span>
                </div>
                <div class="card-body">
                    <p class="card-text">@(exam.Description ?? "Aucune description")</p>
                    <ul class="list-unstyled">
                        <li><i class="fas fa-calendar me-2"></i>@exam.ExamDate.ToString("dd/MM/yyyy")</li>
                        @if (exam.StartTime.HasValue)
                        {
                            <li><i class="fas fa-clock me-2"></i>@exam.StartTime.Value.ToString("hh\\:mm") - @(exam.EndTime?.ToString("hh\\:mm") ?? "?")</li>
                        }
                        @if (!string.IsNullOrEmpty(exam.Location))
                        {
                            <li><i class="fas fa-map-marker-alt me-2"></i>@exam.Location</li>
                        }
                        @if (subject != null)
                        {
                            <li><i class="fas fa-book me-2"></i>@subject.Name</li>
                        }
                    </ul>
                </div>
                <div class="card-footer">
                    <a href="/Exams/Edit/@exam.Id" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></a>
                    <form method="post" action="/Exams/Delete/@exam.Id" class="d-inline" onsubmit="return confirm('Supprimer cet examen?');">
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="fas fa-graduation-cap fa-4x text-muted mb-3"></i>
        <h4 class="text-muted">Aucun examen prevu</h4>
        <a href="/Exams/Create" class="btn btn-primary">Ajouter un examen</a>
    </div>
}