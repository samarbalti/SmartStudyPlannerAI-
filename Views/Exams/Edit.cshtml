@model SmartStudyPlannerAI.Models.DTOs.ExamDTO
@{
    ViewData["Title"] = "Modifier l'examen";
    var subjects = ViewBag.Subjects as List<SmartStudyPlannerAI.Models.Entities.Subject> ?? new();
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h4 class="mb-0"><i class="fas fa-edit me-2"></i>Modifier l'examen</h4>
            </div>
            <div class="card-body">
                <form method="post" action="/Exams/Edit/@Model.Id">
                    <div class="mb-3">
                        <label class="form-label">Titre</label>
                        <input type="text" name="Title" class="form-control" value="@Model.Title" required maxlength="200" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="Description" class="form-control" rows="3">@Model.Description</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Matiere</label>
                        <select name="SubjectId" class="form-select">
                            <option value="">-- Selectionner --</option>
                            @foreach (var subject in subjects)
                            {
                                <option value="@subject.Id" selected="@(Model.SubjectId == subject.Id ? "selected" : null)">@subject.Name</option>
                            }
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Date</label>
                            <input type="date" name="ExamDate" class="form-control" value="@Model.ExamDate.ToString("yyyy-MM-dd")" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Heure debut</label>
                            <input type="time" name="StartTime" class="form-control" value="@(Model.StartTime?.ToString("hh\\:mm"))" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Heure fin</label>
                            <input type="time" name="EndTime" class="form-control" value="@(Model.EndTime?.ToString("hh\\:mm"))" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Lieu</label>
                        <input type="text" name="Location" class="form-control" value="@Model.Location" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Enregistrer
                        </button>
                        <a href="/Exams" class="btn btn-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>