@model SmartStudyPlannerAI.Models.DTOs.StatisticsDTO
@{
    ViewData["Title"] = "Statistiques";
}

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card stat-card bg-primary text-white">
            <div class="card-body text-center">
                <h3>@Model.TotalStudyHours</h3>
                <p class="mb-0">Heures d'etude</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card bg-success text-white">
            <div class="card-body text-center">
                <h3>@Model.CompletedTasks</h3>
                <p class="mb-0">Taches completees</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card bg-warning text-white">
            <div class="card-body text-center">
                <h3>@Model.TotalTasks</h3>
                <p class="mb-0">Total taches</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card bg-info text-white">
            <div class="card-body text-center">
                <h3>@Model.UpcomingExams</h3>
                <p class="mb-0">Examens a venir</p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-chart-bar me-2"></i>Temps d'etude hebdomadaire</h5>
            </div>
            <div class="card-body">
                <canvas id="weeklyChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-chart-pie me-2"></i>Progression par matiere</h5>
            </div>
            <div class="card-body">
                <canvas id="subjectChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-trophy me-2"></i>Progression des matieres</h5>
            </div>
            <div class="card-body">
                @foreach (var progress in Model.SubjectProgresses)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <span>@progress.SubjectName</span>
                            <span>@progress.CompletedTasks / @progress.TotalTasks (@progress.ProgressPercentage.ToString("F0")%)</span>
                        </div>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar @(progress.ProgressPercentage >= 75 ? "bg-success" : progress.ProgressPercentage >= 50 ? "bg-info" : "bg-warning")" 
                                 role="progressbar" style="width: @progress.ProgressPercentage%">
                            </div>
                        </div>
                    </div>
                }
                @if (!Model.SubjectProgresses.Any())
                {
                    <p class="text-muted text-center">Aucune donnee de progression disponible</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/dashboard.js"></script>
}