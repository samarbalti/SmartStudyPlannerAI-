@model SmartStudyPlannerAI.Models.ViewModels.StudyPlanViewModel
@{
    ViewData["Title"] = "Details du planning";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-calendar-week me-2"></i>@Model.StudyPlan?.Title</h2>
    <a href="/StudyPlan" class="btn btn-secondary">Retour</a>
</div>

@if (Model.StudyPlan != null)
{
    <div class="card mb-4">
        <div class="card-body">
            <p class="card-text">@Model.StudyPlan.Description</p>
            <div class="row text-center">
                <div class="col-md-4">
                    <h6>Periode</h6>
                    <p>Du @Model.StudyPlan.StartDate.ToString("dd/MM/yyyy") au @Model.StudyPlan.EndDate.ToString("dd/MM/yyyy")</p>
                </div>
                <div class="col-md-4">
                    <h6>Statut</h6>
                    <span class="badge bg-@(Model.StudyPlan.IsActive ? "success" : "secondary")">
                        @(Model.StudyPlan.IsActive ? "Actif" : "Inactif")
                    </span>
                </div>
                <div class="col-md-4">
                    <h6>Sessions</h6>
                    <p>@Model.Sessions.Count seances</p>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Sessions.Any())
    {
        <h4 class="mb-3">Seances d'etude</h4>
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Matiere</th>
                        <th>Horaire</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var session in Model.Sessions.OrderBy(s => s.Date).ThenBy(s => s.StartTime))
                    {
                        <tr>
                            <td>@session.Date.ToString("dddd dd/MM/yyyy")</td>
                            <td><span class="badge bg-primary">@session.SubjectName</span></td>
                            <td>@session.StartTime.ToString("hh\\:mm") - @session.EndTime.ToString("hh\\:mm")</td>
                            <td>@(session.Notes ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle me-2"></i>
            Aucune seance planifiee. Le planning a peut-etre ete genere mais les donnees sont au format texte.
        </div>
        <div class="card">
            <div class="card-body">
                <pre class="mb-0" style="white-space: pre-wrap;">@Model.StudyPlan.PlanData</pre>
            </div>
        </div>
    }
}