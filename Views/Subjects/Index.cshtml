@model IEnumerable<SmartStudyPlannerAI.Models.Entities.Subject>
@{
    ViewData["Title"] = "Matieres";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-book me-2"></i>Mes matieres</h2>
    <a href="/Subjects/Create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Ajouter une matiere
    </a>
</div>

<div class="row">
    @foreach (var subject in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card subject-card h-100" style="border-left: 4px solid @subject.Color;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <h5 class="card-title">@subject.Name</h5>
                        <div class="dropdown">
                            <button class="btn btn-link text-dark" data-bs-toggle="dropdown">
                                <i class="fas fa-ellipsis-v"></i>
                            </button>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/Subjects/Edit/@subject.Id"><i class="fas fa-edit me-2"></i>Modifier</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form method="post" action="/Subjects/Delete/@subject.Id" onsubmit="return confirm('Supprimer cette matiere?');">
                                        <button type="submit" class="dropdown-item text-danger"><i class="fas fa-trash me-2"></i>Supprimer</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </div>
                    <p class="card-text text-muted">@(subject.Description ?? "Aucune description")</p>
                    @if (!string.IsNullOrEmpty(subject.Category))
                    {
                        <span class="badge bg-secondary">@subject.Category</span>
                    }
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="fas fa-book-open fa-4x text-muted mb-3"></i>
        <h4 class="text-muted">Aucune matiere</h4>
        <p class="text-muted">Commencez par ajouter vos matieres</p>
        <a href="/Subjects/Create" class="btn btn-primary">Ajouter une matiere</a>
    </div>
}